    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "daisyui": "^4.12.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^3.2.7"
