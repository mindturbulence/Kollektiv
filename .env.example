# Copy to .env and fill in. .env is gitignored — never commit real values.

# Obsidian Local REST API plugin key. Required only if you use the
# `obsidian:mcp` / `obsidian:mcp:http` scripts or want `pnpm dev` to start
# the local Obsidian MCP bridge (server.ts). Omit it and the bridge is skipped.
OBSIDIAN_API_KEY=
